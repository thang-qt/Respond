# Database
DATABASE_URL=postgres://respond:respond@localhost:5432/respond?sslmode=disable

# Auth
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
# Signup policy: open | invite_only | closed
AUTH_SIGNUP_MODE=invite_only
# Invite policy (used when AUTH_SIGNUP_MODE=invite_only)
INVITE_TOKEN_TTL=168h
INVITE_MIN_ACCOUNT_AGE=336h
INVITE_REQUIRE_VERIFIED=true

# Server
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:3000

# Frontend (copy into frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Moderation
OPENAI_API_KEY=

# SMTP (transactional email)
SMTP_HOST=smtp.mailhost.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@respond.im
SMTP_FROM_NAME=Respond
SMTP_REQUIRE_TLS=true

# Environment
ENV=development
